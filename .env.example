# Claude API
ANTHROPIC_API_KEY=

# Voyage AI embeddingy
VOYAGE_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Admin sekce (všechny hodnoty povinné)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Podpisový klíč session cookie — dlouhý náhodný řetězec (např. `openssl rand -hex 32`)
SESSION_SECRET=

# Model pro chat (volitelné — default claude-sonnet-4-6)
# CHAT_MODEL=claude-sonnet-4-6

# Shrnutí poptávek běží přes Mistral (@ai-sdk/mistral) — prototypový test
# (Varianta B, viz docs/plans/mistral_summary_experiment_plan.md).
# Klíč je povinný, aby shrnutí fungovalo; bez něj se lead uloží bez shrnutí.
MISTRAL_API_KEY=
# Model pro shrnutí poptávek (volitelné — default mistral-small-latest)
# SUMMARY_MODEL=mistral-small-latest

# RAG parametry (výchozí hodnoty jsou předvyplněny)
TOP_K=5
SIMILARITY_THRESHOLD=0.35
LLM_TEMPERATURE=0.2

# Langfuse observabilita (volitelné — bez nich app funguje, jen se neloguje)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Cíl eval runneru (scripts/langfuse-eval.mjs) — nasazená URL Kecala
# KECALO_BASE_URL=https://kecalo.vercel.app
