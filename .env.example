# Claude API
ANTHROPIC_API_KEY=

# Voyage AI embeddingy
VOYAGE_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Admin sekce (všechny hodnoty povinné)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Podpisový klíč session cookie — dlouhý náhodný řetězec (např. `openssl rand -hex 32`)
SESSION_SECRET=

# RAG parametry (výchozí hodnoty jsou předvyplněny)
TOP_K=5
SIMILARITY_THRESHOLD=0.35
LLM_TEMPERATURE=0.2

# Langfuse observabilita (volitelné — bez nich app funguje, jen se neloguje)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
